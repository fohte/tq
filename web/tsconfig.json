{
  "extends": [
    "@tsconfig/node-lts/tsconfig.json",
    "@tsconfig/strictest/tsconfig.json"
  ],
  "include": ["src", ".storybook/**/*", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["**/*.cjs"],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@web/*": ["src/*"],
      "@api/*": ["../api/src/*"],
      "@storybook-config/*": [".storybook/*"]
    }
  }
}
