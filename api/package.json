{
  "name": "api",
  "private": true,
  "type": "module",
  "exports": {
    "./types": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/db/migrate.ts --format esm --out-dir dist --clean",
    "start": "node dist/index.js",
    "test": "conc pnpm:test:type pnpm:test:unit",
    "test:type": "tsc --noEmit",
    "test:unit": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@hono/node-server": "1.19.13",
    "@hono/zod-validator": "0.7.6",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.8",
    "postgres": "3.4.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "tsup": "8.5.1",
    "tsx": "4.21.0"
  }
}
