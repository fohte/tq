#!/usr/bin/env bash
#
# Start the local Postgres container and write .env.runtime with the
# actual host port, since docker-compose.yml publishes it on a random
# port to avoid clashing with other projects.
#
# Usage:
#   scripts/db-up

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

docker compose up -d --wait

port="$(docker compose port db 5432 | cut -d: -f2)"

cat > .env.runtime << EOF
# Generated by scripts/db-up — do not edit by hand.
# Re-run scripts/db-up after the db container is recreated to refresh the port.
DATABASE_URL=postgresql://tq:tq@localhost:${port}/tq_dev
TEST_DATABASE_URL=postgresql://tq:tq@localhost:${port}/tq_test
EOF

echo "Wrote .env.runtime (db port: ${port})"
